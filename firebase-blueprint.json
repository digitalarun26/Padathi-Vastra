{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A saree product in the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Price in INR" },
        "description": { "type": "string", "description": "Detailed description" },
        "fabric": { "type": "string", "description": "Fabric type (e.g., Silk, Cotton)" },
        "category": { "type": "string", "description": "Category (e.g., Kanchipuram, Banarasi)" },
        "color": { "type": "string", "description": "Primary color" },
        "imageUrl": { "type": "string", "description": "URL to product image" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["name", "price", "category", "imageUrl"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "number" }
            }
          }
        },
        "total": { "type": "number", "description": "Total order amount" },
        "status": { "type": "string", "enum": ["pending", "shipped", "delivered"], "description": "Order status" },
        "address": { "type": "string", "description": "Shipping address" },
        "mapLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time", "description": "Order timestamp" }
      },
      "required": ["userId", "products", "total", "status", "address"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of saree products"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
